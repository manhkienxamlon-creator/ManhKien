local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local Window = Rayfield:CreateWindow({
    Name = "KienDay (VNnumberonez)",
    LoadingTitle = "Đợi tý ko phải vội🐧",
    LoadingSubtitle = "VNnumberonez",
    ConfigurationSaving = {Enabled = false}
})

local CombatTab = Window:CreateTab("Combat & ESP", nil)

_G.hitboxEnabled = false
_G.hitboxSize = 2
_G.espEnabled = false

CombatTab:CreateToggle({
    Name = "Bật hitbox đi thg ku e🖕",
    CurrentValue = false,
    Callback = function(Value)
        _G.hitboxEnabled = Value
        if not Value then
            for _, v in pairs(Players:GetPlayers()) do
                if v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    v.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                    v.Character.HumanoidRootPart.Transparency = 1
                end
            end
        end
    end,
})

CombatTab:CreateSlider({
    Name = "HitBox",
    Range = {1, 25},
    Increment = 1,
    CurrentValue = 2,
    Callback = function(Value)
        _G.hitboxSize = Value
    end,
})

CombatTab:CreateToggle({
    Name = "Máu esp🖕🗿",
    CurrentValue = false,
    Callback = function(Value)
        _G.espEnabled = Value
        if not Value then
            for _, v in pairs(Players:GetPlayers()) do
                if v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.HumanoidRootPart:FindFirstChild("Máu esp🖕🗿") then
                    v.Character.HumanoidRootPart["Máu esp🖕🗿"]:Destroy()
                end
            end
        end
    end,
})

RunService.Heartbeat:Connect(function()
    if _G.hitboxEnabled then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= Players.LocalPlayer and v.Character then
                for _, part in pairs(v.Character:GetChildren()) do
                    if part.Name:match("Torso") or part.Name == "HumanoidRootPart" then
                        part.Size = Vector3.new(_G.hitboxSize, _G.hitboxSize, _G.hitboxSize)
                        part.Transparency = 0.7
                        part.CanCollide = false
                    end
                end
            end
        end
    end

    if _G.espEnabled then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local root = v.Character.HumanoidRootPart
                if not root:FindFirstChild("Máu esp🖕🗿") then
                    local billboard = Instance.new("BillboardGui", root)
                    billboard.Name = "Máu esp🖕🗿"
                    billboard.Size = UDim2.new(0, 100, 0, 50)
                    billboard.AlwaysOnTop = true
                    local text = Instance.new("TextLabel", billboard)
                    text.Size = UDim2.new(1, 0, 1, 0)
                    text.BackgroundTransparency = 1
                    text.TextColor3 = Color3.fromRGB(255, 255, 255)
                    text.Font = Enum.Font.SourceSansBold
                    text.TextSize = 18
                end
                root["Máu esp🖕🗿"].TextLabel.Text = v.Name .. " | HP: " .. math.floor(v.Character.Humanoid.Health)
            end
        end
    end
end)
