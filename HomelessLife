-- 2. TÍNH NĂNG HITBOX (1 - 7)
---
local HitboxSize = 2 
MainTab:CreateSlider({
   Name = "Hitbox",
   Range = {1, 7},
   Increment = 0.5,
   CurrentValue = 2,
   Flag = "HitboxSlider",
   Callback = function(Value)
