-- Biến cấu hình
_G.Speed = 16
_G.Jump = 50
_G.HitboxSize = 2
_G.GodMode = false
_G.InfJump = false
_G.Noclip = false
_G.ESP = false
_G.FullBright = false

-- Vòng lặp duy trì stats & Light (Anti-Reset)
task.spawn(function()
    while true do
        local p = game.Players.LocalPlayer
        local char = p.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.WalkSpeed = _G.Speed
                hum.JumpPower = _G.Jump
                if _G.GodMode then
                    hum.MaxHealth = 1e18
                    hum.Health = 1e18
                end
            end
            if _G.Noclip then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end
        end
        
        -- Xử lý phát sáng toàn Server (FullBright)
        if _G.FullBright then
            game:GetService("Lighting").Brightness = 2
            game:GetService("Lighting").ClockTime = 14
            game:GetService("Lighting").FogEnd = 100000
            game:GetService("Lighting").GlobalShadows = false
            game:GetService("Lighting").Ambient = Color3.fromRGB(255, 255, 255)
        end
        
        task.wait(0.1)
    end
end)

-- Infinite Jump
game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.InfJump then
        local p = game.Players.LocalPlayer
        if p.Character and p.Character:FindFirstChildOfClass("Humanoid") then
            p.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
        end
    end
end)

-- Hitbox & ESP (Khóa cứng)
task.spawn(function()
    while true do
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character then
                local root = v.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                    root.Transparency = 0.7
                    root.CanCollide = false
                end
                
                if _G.ESP and not v.Character:FindFirstChild("ESPHighlight") then
                    local hl = Instance.new("Highlight", v.Character)
                    hl.Name = "ESPHighlight"
                    task.spawn(function()
                        while hl.Parent and _G.ESP do
                            hl.FillColor = Color3.fromHSV(tick() % 5 / 5, 1, 1)
                            task.wait()
                        end
                        if hl then hl:Destroy() end
                    end)
                end
            end
        end
        task.wait(0.5)
    end
end)

