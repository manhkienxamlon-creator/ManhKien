-- ==========================================
-- LOGIC AUTO LOOT
-- ==========================================
local function IsTargetItem(item)
    local name = string.lower(item.Name)
    return name == "gold" or name == "diamond" or name == "emerald"
end

local function BatDauNhatDo()
    while _G.AutoLoot do
        local player = game.Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local rootPart = character:WaitForChild("HumanoidRootPart", 5)
        if rootPart then
            for _, item in ipairs(workspace:GetDescendants()) do
                if not _G.AutoLoot then break end
                if item:IsA("BasePart") and IsTargetItem(item) then
                    if item.Parent and not item:IsDescendantOf(player.Character) then
                        rootPart.CFrame = item.CFrame
                        task.wait(0.5)
                    end
                elseif item:IsA("ProximityPrompt") and item.Parent and IsTargetItem(item.Parent) then
                    local parentPart = item.Parent
                    if parentPart:IsA("BasePart") then
                        rootPart.CFrame = parentPart.CFrame + Vector3.new(0, 2, 0)
                        task.wait(0.1)
                        if fireproximityprompt then fireproximityprompt(item) else item:InputHoldBegin(); task.wait(item.HoldDuration); item:InputHoldEnd() end
                        task.wait(0.5)
                    end
                end
            end
        end
        task.wait(0.2)
    end
end

-- ==========================================
-- LOGIC ESP
-- ==========================================
local function CreateTag(model, text, color)
    local head = model:FindFirstChild("Head") or model:FindFirstChildWhichIsA("BasePart")
    if not head then return end
    local oldTag = model:FindFirstChild("KienManhX_NameTag")
    if oldTag then oldTag:Destroy() end
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "KienManhX_NameTag"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Adornee = head
    billboard.Parent = model
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color
    label.TextSize = 14
    label.Font = Enum.Font.SourceSansBold
    label.TextStrokeTransparency = 0
    label.Parent = billboard
    return label
end

local function ApplyESP(model, color, toggleVariable, isPlayer)
    if not model:FindFirstChildOfClass("Humanoid") then return end
    local highlight = model:FindFirstChild("KienManhX_Highlight")
    if _G[toggleVariable] then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "KienManhX_Highlight"
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.FillTransparency = 0.6
            highlight.Parent = model
        end
        highlight.FillColor = color
    else
        if highlight then highlight:Destroy() end
        local tag = model:FindFirstChild("KienManhX_NameTag")
        if tag then tag:Destroy() end
        return
    end
    local localPlayer = game.Players.LocalPlayer
    local root = model:FindFirstChild("HumanoidRootPart")
    local myRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root and myRoot then
        local distance = math.floor((root.Position - myRoot.Position).Magnitude)
        local displayName = isPlayer and model.Name or "[NPC] " .. model.Name
        local label = model:FindFirstChild("KienManhX_NameTag") and model["KienManhX_NameTag"]:FindFirstChildOfClass("TextLabel")
        if not label then label = CreateTag(model, displayName .. " [" .. distance .. "m]", color) else label.Text = displayName .. " [" .. distance .. "m]" end
    end
end

task.spawn(function()
    while task.wait(0.5) do
        local localPlayer = game.Players.LocalPlayer
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and obj ~= localPlayer.Character then
                local playerInstance = game.Players:GetPlayerFromCharacter(obj)
                if playerInstance then ApplyESP(obj, Color3.fromRGB(0, 150, 255), "EspPlayer", true) else ApplyESP(obj, Color3.fromRGB(255, 20, 20), "EspNpc", false) end
            end
        end
    end
end)

local function ClearESP(toggleVariable)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "KienManhX_Highlight" or obj.Name == "KienManhX_NameTag" then
            local parentModel = obj.Parent
            if parentModel and parentModel:IsA("Model") then
                local isPlayer = game.Players:GetPlayerFromCharacter(parentModel)
                if (isPlayer and toggleVariable == "EspPlayer") or (not isPlayer and toggleVariable == "EspNpc") then obj:Destroy() end
            end
        end
    end
end

